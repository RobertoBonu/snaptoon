modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
# V2 — Next.js (frontend) + FastAPI (backend) tramite proxy interno.
# Streamlit (legacy) NON viene più avviato.
build = ["sh", "build_v2.sh"]
run = ["sh", "start_v2.sh"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
REPLIT_OBJECT_STORAGE_BUCKET = "replit-objstore-44e0e069-0f69-4c62-9ed2-929bba33dc83"

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "glibcLocales", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "libyaml", "openjpeg", "rustc", "tcl", "tk", "zlib"]
