modules = ["python-3.13"]
run = "streamlit run app.py --server.port 8080 --server.address 0.0.0.0 --server.headless true"

[nix]
channel = "stable-24_05"

[deployment]
run = ["streamlit", "run", "app.py", "--server.port", "8080", "--server.address", "0.0.0.0", "--server.headless", "true"]
deploymentTarget = "gce"

[env]
PYTHONUNBUFFERED = "1"

[agent]
expertMode = true
