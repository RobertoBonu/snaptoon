# SnapToon — variabili ambiente
# Copia in `.env` e compila i valori. Su Replit usa Secrets (Tools → Secrets).

# ============================================================
# AI Providers (server-side, le tue chiavi)
# ============================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Modelli (default ragionevoli)
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_IMAGE_MODEL=gpt-image-2
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ============================================================
# Database (Replit Postgres managed)
# ============================================================
DATABASE_URL=

# ============================================================
# Object Storage (Replit)
# ============================================================
REPLIT_OBJECT_STORAGE_BUCKET=

# ============================================================
# Auth
# ============================================================
# Chiave per firmare le sessioni (random 32+ char)
SESSION_SECRET=

# Admin email — questa è l'unica email con accesso al pannello Admin
ADMIN_EMAIL=aicreator.info@gmail.com

# ============================================================
# App config
# ============================================================
APP_ENV=development  # development | production
APP_BASE_URL=https://snaptoon.art
